#!/usr/bin/env bash
set -euo pipefail

CPS_VERSION="0.6.0"

CPS_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"

source "$CPS_ROOT/lib/utils.sh"
source "$CPS_ROOT/lib/git.sh"
source "$CPS_ROOT/lib/crypto.sh"
source "$CPS_ROOT/lib/core.sh"
source "$CPS_ROOT/lib/shell.sh"

show_help() {
  cat << EOF
${BOLD}cps${RESET} — Claude Profile Switch v${CPS_VERSION}

${BOLD}USAGE${RESET}
  cps <command> [args]

${BOLD}PROFILE COMMANDS${RESET}
  init                    Initialize CPS, snapshot current config as 'default'
  create <name> [flags]   Create profile (--from <p> | --fresh | --template <url>)
  use <name>              Switch to profile
  pick                    Interactive profile picker (default with no args)
  list [--tag <t>]        List all profiles (filter by tag)
  current                 Print active profile name
  delete <name>           Delete a profile
  rename <old> <new>      Rename a profile
  export <name> [path]    Export profile as .tar.gz archive
  import <archive> [name] Import profile from archive
  clone <url>             Clone profiles from remote (first-time setup)
  status                  Show diff between profile and live state
  snapshot [--desktop]    Save live config back to profile
  link <item> <profile>   Symlink item from another profile (shared layer)
  unlink <item>           Remove symlink, restore original
  lock <name>             Prevent modifications to a profile
  unlock <name>           Remove lock from a profile
  tag <profile> <tag>     Add tag to profile
  untag <profile> <tag>   Remove tag from profile
  tags                    List all tags with counts
  audit [filters]         Query audit log (--action, --profile, --since, --limit)

${BOLD}GIT BACKUP & SYNC${RESET}
  save [message]          Commit current state with message
  log [profile]           Show change history
  rollback <commit>       Restore to previous commit
  remote [url]            Get/set git remote
  push                    Push to remote
  pull                    Pull from remote
  sync enable <url>       Enable auto-sync to remote
  sync disable            Disable auto-sync
  sync status             Show sync state (default)
  sync schedule [interval] Install periodic sync timer (default: 30m)
  sync unschedule         Remove sync timer

${BOLD}CLAUDE DESKTOP${RESET}
  desktop save            Save Claude Desktop config to profile
  desktop restore         Restore Claude Desktop config from profile
  desktop status          Check if desktop config is synced

${BOLD}UTILITY${RESET}
  diff [p1] [p2]          Compare two profiles (default: active vs all)
  edit [name]             Open profile dir in \$EDITOR
  doctor                  Health check (paths, encryption, git, integrity)
  upgrade                 Self-update to latest version
  shell-init              Output shell integration code
  help                    Show this help

${BOLD}ENCRYPTION${RESET}
  init --key <path>       Import age key (for new machine setup)
  Credentials auto-encrypted if age is installed during init.

${BOLD}SHELL INTEGRATION${RESET}
  Add to ~/.zshrc or ~/.bashrc:
    eval "\$(cps shell-init)"

${BOLD}EXAMPLES${RESET}
  cps init                          # First-time setup
  cps create work                   # New profile from current
  cps create test --from work       # New profile from 'work'
  cps create experiment --fresh     # Clean profile, no inherited config
  cps rename work office            # Rename profile
  cps export work ./work-backup.cps.tar.gz  # Export
  cps import ./work-backup.cps.tar.gz       # Import
  cps clone git@github.com:user/cps-profiles.git  # First-time setup
  cps sync enable git@github.com:user/cps-profiles.git  # Auto-sync
  cps sync status                   # Check sync state
EOF
}

parse_init_args() {
  local key_path=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --key)
        shift
        key_path="${1:-}"
        [[ -z "$key_path" ]] && die "--key requires a file path"
        ;;
      *) die "Unknown init option: $1" ;;
    esac
    shift
  done

  cmd_init "$key_path"
}

parse_create_args() {
  local name=""
  local from=""
  local fresh="0"
  local template=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from)
        shift
        from="${1:-}"
        [[ -z "$from" ]] && die "--from requires a profile name"
        ;;
      --fresh)
        fresh="1"
        ;;
      --template)
        shift
        template="${1:-}"
        [[ -z "$template" ]] && die "--template requires a URL"
        ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        else
          die "Unexpected argument: $1"
        fi
        ;;
    esac
    shift
  done

  local flags=0
  [[ "$fresh" == "1" ]] && flags=$((flags + 1))
  [[ -n "$from" ]] && flags=$((flags + 1))
  [[ -n "$template" ]] && flags=$((flags + 1))
  if [[ $flags -gt 1 ]]; then
    die "--fresh, --from, and --template are mutually exclusive."
  fi

  cmd_create "$name" "$from" "$fresh" "$template"
}

parse_list_args() {
  local tag=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tag) shift; tag="${1:-}" ;;
      *) die "Unknown option: $1" ;;
    esac
    shift
  done
  cmd_list "$tag"
}

main() {
  local command="${1:-pick}"
  shift 2>/dev/null || true

  case "$command" in
    pick)        cmd_pick ;;
    init)        parse_init_args "$@" ;;
    create)      parse_create_args "$@" ;;
    use)         cmd_use "${1:-}" ;;
    list|ls)     parse_list_args "$@" ;;
    current)     cmd_current ;;
    delete|rm)   cmd_delete "${1:-}" ;;
    export)      cmd_export "${1:-}" "${2:-}" ;;
    import)      cmd_import "${1:-}" "${2:-}" ;;
    rename|mv)   cmd_rename "${1:-}" "${2:-}" ;;
    clone)       cmd_clone "${1:-}" ;;
    link)        cmd_link "${1:-}" "${2:-}" ;;
    unlink)      cmd_unlink "${1:-}" ;;
    lock)        cmd_lock "${1:-}" ;;
    unlock)      cmd_unlock "${1:-}" ;;
    status)      cmd_status ;;
    snapshot)    shift 2>/dev/null || true; cmd_snapshot "$@" ;;
    desktop)     cmd_desktop "${1:-}" ;;
    tag)         cmd_tag "${1:-}" "${2:-}" ;;
    untag)       cmd_untag "${1:-}" "${2:-}" ;;
    tags)        cmd_tags ;;
    audit)       cmd_audit "$@" ;;
    save)        cmd_save "${1:-}" ;;
    log)         cmd_log "${1:-}" ;;
    rollback)    cmd_rollback "${1:-}" ;;
    remote)      cmd_remote "${1:-}" ;;
    push)        cmd_push ;;
    pull)        cmd_pull ;;
    sync)        cmd_sync "${1:-}" "${2:-}" ;;
    diff)        cmd_diff "${1:-}" "${2:-}" ;;
    edit)        cmd_edit "${1:-}" ;;
    doctor)      cmd_doctor ;;
    upgrade)     cmd_upgrade ;;
    shell-init)  cmd_shell_init ;;
    help|--help|-h) show_help ;;
    version|--version|-v) echo "cps $CPS_VERSION" ;;
    *)           err "Unknown command: $command"; echo ""; show_help; exit 1 ;;
  esac
}

main "$@"
