pkgname=cps
pkgver=0.4.0
pkgrel=1
pkgdesc="Switch between isolated Claude Code profiles"
arch=('any')
url="https://github.com/guibes/claude-profile-switch"
license=('MIT')
depends=('bash' 'git')
optdepends=('age: credential encryption')
source=("$pkgname-$pkgver::git+$url.git#tag=v$pkgver")
sha256sums=('SKIP')

package() {
  cd "$pkgname-$pkgver"

  install -Dm755 bin/cps "$pkgdir/usr/bin/cps"

  install -Dm644 lib/utils.sh "$pkgdir/usr/lib/cps/utils.sh"
  install -Dm644 lib/git.sh "$pkgdir/usr/lib/cps/git.sh"
  install -Dm644 lib/crypto.sh "$pkgdir/usr/lib/cps/crypto.sh"
  install -Dm644 lib/core.sh "$pkgdir/usr/lib/cps/core.sh"
  install -Dm644 lib/shell.sh "$pkgdir/usr/lib/cps/shell.sh"

  install -Dm644 man/cps.1 "$pkgdir/usr/share/man/man1/cps.1"

  install -Dm644 completions/cps.bash "$pkgdir/usr/share/bash-completion/completions/cps"
  install -Dm644 completions/cps.zsh "$pkgdir/usr/share/zsh/site-functions/_cps"

  install -Dm644 oh-my-zsh/cps/cps.plugin.zsh "$pkgdir/usr/share/cps/oh-my-zsh/cps.plugin.zsh"

  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

  sed -i "s|^CPS_ROOT=.*|CPS_ROOT=/usr/lib/cps/..|" "$pkgdir/usr/bin/cps"
}
